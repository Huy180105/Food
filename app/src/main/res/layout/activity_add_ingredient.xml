<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            app:cardCornerRadius="80dp"
            app:cardElevation="4dp">
            <ImageView
                android:id="@+id/imgIngredient"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_camera"
                android:background="#E0E0E0"
                android:contentDescription="Ảnh nguyên liệu" />
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnPickImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:text="Tìm ảnh trên Google"
            android:textColor="#FF5722"
            style="@style/Widget.AppCompat.Button.Borderless.Colored" />

        <EditText
            android:id="@+id/edtImageName"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:hint="Nhập tên file ảnh (ví dụ: thit_bo)"
            android:background="@android:drawable/edit_text"
            android:paddingHorizontal="15dp"
            android:importantForAutofill="no"
            android:inputType="text" />

        <EditText
            android:id="@+id/edtName"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:hint="Tên nguyên liệu"
            android:background="@android:drawable/edit_text"
            android:paddingHorizontal="15dp"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/edtQuantity"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:hint="Số lượng"
            android:inputType="numberDecimal"
            android:background="@android:drawable/edit_text"
            android:paddingHorizontal="15dp"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/edtUnit"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:hint="Đơn vị tính (ví dụ: kg, lít...)"
            android:background="@android:drawable/edit_text"
            android:paddingHorizontal="15dp"
            android:importantForAutofill="no" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:text="Thêm"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:text="Hủy"
                android:backgroundTint="#9E9E9E"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>