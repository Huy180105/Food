<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/txtTieuDeDialogNL"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Them nguyen lieu"
        android:textSize="20sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/edtTenNL"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:hint="Ten nguyen lieu" />

    <EditText
        android:id="@+id/edtSoLuongNL"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:hint="So luong"
        android:inputType="numberDecimal" />

    <EditText
        android:id="@+id/edtDonViNL"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Don vi" />

    <Button
        android:id="@+id/btnLuuNL"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Luu" />

</LinearLayout>
