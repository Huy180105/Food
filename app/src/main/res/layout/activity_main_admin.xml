<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:background="#F8F9FA"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavigation"
        android:scrollbars="none">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/bg_header_gradient"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Khám phá Ẩm thực Việt"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>


            </LinearLayout>

            <TextView
                android:text="Tinh hoa 3 miền"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_margin="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:clipToPadding="false"
                android:scrollbars="none">

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <androidx.cardview.widget.CardView
                        android:layout_width="200dp"
                        android:layout_height="250dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="15dp"
                        app:cardElevation="4dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <ImageView
                                android:src="@drawable/img_mien_bac"
                                android:scaleType="centerCrop"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"/>
                            <View android:background="#66000000" android:layout_width="match_parent" android:layout_height="match_parent"/>
                            <TextView
                                android:text="MIỀN BẮC\nTinh tế &amp; Thanh tao"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:layout_alignParentBottom="true"
                                android:layout_margin="12dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="200dp"
                        android:layout_height="250dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="15dp"
                        app:cardElevation="4dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <ImageView
                                android:src="@drawable/img_mien_trung"
                                android:scaleType="centerCrop"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"/>
                            <View android:background="#66000000" android:layout_width="match_parent" android:layout_height="match_parent"/>
                            <TextView
                                android:text="MIỀN TRUNG\nĐậm đà &amp; Cay nồng"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:layout_alignParentBottom="true"
                                android:layout_margin="12dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="200dp"
                        android:layout_height="250dp"
                        android:layout_marginEnd="16dp"
                        app:cardCornerRadius="15dp"
                        app:cardElevation="4dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <ImageView
                                android:src="@drawable/img_mien_nam"
                                android:scaleType="centerCrop"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"/>
                            <View android:background="#66000000" android:layout_width="match_parent" android:layout_height="match_parent"/>
                            <TextView
                                android:text="MIỀN NAM\nHào sảng &amp; Ngọt ngào"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:layout_alignParentBottom="true"
                                android:layout_margin="12dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:text="Gợi ý món ngon hôm nay"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_margin="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:text="🥢 Đặc sản Miền Bắc"
                            android:textColor="#FF5722"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:text="Phở Bò Truyền Thống Hà Nội"
                            android:textStyle="bold"
                            android:textSize="17sp"
                            android:layout_marginTop="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:text="Nước dùng thanh ngọt từ xương hầm, bánh phở mềm dẻo. Một lựa chọn tuyệt vời cho ngày se lạnh tại Thủ đô."
                            android:textSize="14sp"
                            android:textColor="#616161"
                            android:lineSpacingExtra="4dp"
                            android:layout_marginTop="8dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:text="🌶️ Đặc sản Miền Trung"
                            android:textColor="#E65100"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:text="Bún Bò Huế Đậm Đà"
                            android:textStyle="bold"
                            android:textSize="17sp"
                            android:layout_marginTop="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:text="Hương vị mắm ruốc nồng nàn hòa quyện cùng vị cay đặc trưng. Đánh thức vị giác với sự đậm đà khó quên."
                            android:textSize="14sp"
                            android:textColor="#616161"
                            android:lineSpacingExtra="4dp"
                            android:layout_marginTop="8dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:text="🥥 Đặc sản Miền Nam"
                            android:textColor="#2E7D32"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:text="Cơm Tấm Sườn Bì Chả"
                            android:textStyle="bold"
                            android:textSize="17sp"
                            android:layout_marginTop="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:text="Sườn nướng vàng óng thơm mùi mật ong, ăn kèm nước mắm kẹo đặc sánh. Mang trọn vị hào sảng phương Nam."
                            android:textSize="14sp"
                            android:textColor="#616161"
                            android:lineSpacingExtra="4dp"
                            android:layout_marginTop="8dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_alignParentBottom="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content">
            <ImageView
                android:src="@drawable/ic_home"
                android:layout_width="24dp"
                android:layout_height="24dp"
                app:tint="#FF0000"/>
            <TextView
                android:text="Trang chủ"
                android:textSize="12sp"
                android:textColor="#FF0000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnQlyMonAn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_food"
                android:clickable="false"
                android:focusable="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Món ăn"
                android:textSize="12sp"
                android:textColor="#000000"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content">
            <ImageView
                android:src="@drawable/ic_order"
                android:layout_width="24dp"
                android:layout_height="24dp"/>
            <TextView
                android:text="Hóa đơn"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content">
            <ImageView
                android:src="@drawable/ic_user"
                android:layout_width="24dp"
                android:layout_height="24dp"/>
            <TextView
                android:text="Cá nhân"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>